{
  "preset": "balanced",
  "semanticFallback": {
    "enabled": true,
    "model": "github-copilot/gpt-5.3-codex-mini",
    "mode": "out_of_band",
    "timeoutMs": 4000,
    "maxChecksPerSession": 1
  },
  "reliabilityRuntime": {
    "enabled": true,
    "mode": "shadow",
    "artifactRoot": ".opencode/reliability",
    "flushOnSessionEnd": true
  }
}
